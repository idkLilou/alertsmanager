{#
 Alerts Manager form (Twig) - styled like News plugin
#}

{% extends "generic_show_form.html.twig" %}
{% import 'components/form/fields_macros.html.twig' as fields %}

{% set params = params ?? [] %}

{% block form_fields %}

    {% set base_option = { 'is_horizontal': false } %}
    {% set base_option_small = { 'field_class': 'col-xxl-4 col-xl-6' }|merge(base_option) %}

    {{ fields.textField(
        'name',
        item.fields.name,
        __('Name', 'alertsmanager'),
        base_option
    ) }}

    {{ fields.textareaField(
        'description',
        item.fields.description,
        __('Description', 'alertsmanager'),
        { 'full_width': true, 'enable_richtext': false }|merge(base_option)
    ) }}

    {{ fields.dropdownYesNo(
        'is_active',
        item.fields.is_active,
        __('Active', 'alertsmanager'),
        base_option
    ) }}

    <div class="hr-text">
        <i class="ti ti-mail"></i>
        <span>{{ __('Mail', 'alertsmanager') }}</span>
    </div>

    {{ fields.textField(
        'mail_subject',
        item.fields.mail_subject,
        __('Mail subject', 'alertsmanager'),
        base_option
    ) }}

    {{ fields.textareaField(
        'mail_content',
        item.fields.mail_content,
        __('Mail content', 'alertsmanager'),
        { 'full_width': true, 'enable_richtext': true }|merge(base_option)
    ) }}

    <div class="hr-text preview-section {{ item.isNewItem() ? "d-none" : "" }}">
        <i class="ti ti-eye"></i>
        <span>{{ __('Preview', 'alertsmanager') }}</span>
    </div>

    <div class="alert-preview"></div>

    <div class="hr-text">
        <i class="ti ti-target"></i>
        <span>{{ __('Targets', 'alertsmanager') }}</span>
    </div>

    {# Targets: we render a simple selector block compatible with GLPI look #}
    <div class="row">
        <div class="col-xxl-4 col-xl-6">
            <label class="control-label">{{ __('Target type', 'alertsmanager') }}</label>
            <select id="alert_target_type" name="target_type" class="form-select w-100 alertsmanager-target-type">
                <option value="">-- {{ __('Select', 'alertsmanager') }} --</option>
                <option value="User" {{ item.fields.target_type == 'User' ? 'selected' : '' }}>{{ __('User', 'alertsmanager') }}</option>
                <option value="Group" {{ item.fields.target_type == 'Group' ? 'selected' : '' }}>{{ __('Group', 'alertsmanager') }}</option>
                <option value="Profile" {{ item.fields.target_type == 'Profile' ? 'selected' : '' }}>{{ __('Profile', 'alertsmanager') }}</option>
            </select>
        </div>

        <div class="col-xxl-8 col-xl-6 mt-3 mt-xl-0">
            <label class="control-label">{{ __('Targets', 'alertsmanager') }}</label>
            <select id="alert_targets" name="targets[]" class="form-select w-100 alertsmanager-targets" multiple data-placeholder="-- {{ __('Select', 'alertsmanager') }} --">
                {# Options will be filled server-side by the controller or via JS/AJAX; keep placeholder values if empty #}
                {% for t in item.fields._targets ?? [] %}
                    <option value="{{ t.id }}" selected>{{ t.label }}</option>
                {% endfor %}
            </select>
            <div id="alert_targets_table_container" class="mt-3"></div>
        </div>
    </div>

    <div class="hr-text mt-3">
        <i class="ti ti-clock"></i>
        <span>{{ __('Triggers', 'alertsmanager') }}</span>
    </div>

    <div class="row">
        <div class="col-xxl-4 col-xl-6">
            <label class="control-label">{{ __('Observed field', 'alertsmanager') }}</label>
            <select id="alert_observed_field" name="observed_field" class="form-select w-100">
                <option value="">-- {{ __('Select', 'alertsmanager') }} --</option>
                {% for field in item.fields._available_fields ?? [] %}
                    <option value="{{ field.id }}" {{ item.fields.observed_field == field.id ? 'selected' : '' }}>{{ field.label }}</option>
                {% endfor %}
            </select>
        </div>
    </div>

    <div class="row">
        <div class="col-xxl-4 col-xl-6">
            {{ fields.textField('trigger_months_before', item.fields.trigger_months_before, __('Months before', 'alertsmanager'), base_option_small) }}
        </div>
        <div class="col-xxl-4 col-xl-6">
            {{ fields.textField('trigger_days_before', item.fields.trigger_days_before, __('Days before', 'alertsmanager'), base_option_small) }}
        </div>
    </div>

    {{ fields.dropdownArrayField(
        'frequency',
        item.fields.frequency,
        {
            '': __('-- Select --', 'alertsmanager'),
            'daily': __('Daily', 'alertsmanager'),
            'weekly': __('Weekly', 'alertsmanager'),
            'monthly': __('Monthly', 'alertsmanager')
        },
        __('Frequency', 'alertsmanager'),
        base_option_small
    ) }}

    <script>
        (function() {
            const initialTargets = {{ (item.fields._targets|default([]))|json_encode()|raw }};

            function getTargetsSelect() {
                return document.getElementById('alert_targets');
            }

            function getTargetTypeSelect() {
                return document.getElementById('alert_target_type');
            }

            function getTargetsTableContainer() {
                return document.getElementById('alert_targets_table_container');
            }

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function enhanceTargetsSelect() {
                const targetsSelect = getTargetsSelect();
                if (!targetsSelect) {
                    console.log('[alertsmanager] enhanceTargetsSelect: select element not found');
                    return;
                }
                
                if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
                    console.log('[alertsmanager] enhanceTargetsSelect: jQuery or select2 not available');
                    return;
                }

                const $targets = window.jQuery(targetsSelect);
                const alreadyInitialized = $targets.hasClass('select2-hidden-accessible');
                
                if (alreadyInitialized) {
                    console.log('[alertsmanager] enhanceTargetsSelect: destroying existing select2 instance');
                    try {
                        $targets.select2('destroy');
                    } catch (e) {
                        console.warn('[alertsmanager] Failed to destroy select2:', e);
                    }
                }

                try {
                    $targets.select2({
                        width: '100%',
                        closeOnSelect: false,
                        placeholder: targetsSelect.dataset.placeholder || '-- Select --',
                        allowClear: true,
                        minimumResultsForSearch: 0,
                        dropdownAutoWidth: false
                    });
                    console.log('[alertsmanager] enhanceTargetsSelect: select2 initialized successfully');

                    const select2Container = $targets.next('.select2');
                    if (select2Container.length) {
                        select2Container.addClass('alertsmanager-select2-wrapper');
                    }
                } catch (e) {
                    console.error('[alertsmanager] Failed to initialize select2:', e);
                }
            }

            function getSelectedTargets() {
                const targetsSelect = getTargetsSelect();
                if (!targetsSelect) {
                    return [];
                }

                // Try to use select2 API if available, otherwise fall back to DOM
                if (window.jQuery && window.jQuery(targetsSelect).hasClass('select2-hidden-accessible')) {
                    const values = window.jQuery(targetsSelect).val();
                    if (!values || values.length === 0) {
                        return [];
                    }
                    
                    // Get the labels from options
                    const selectedArray = Array.isArray(values) ? values : [values];
                    return selectedArray.map(function(id) {
                        const option = targetsSelect.querySelector('option[value="' + CSS.escape(String(id)) + '"]');
                        return {
                            id: id,
                            label: option ? option.textContent : String(id)
                        };
                    });
                }

                // Fallback: use native DOM API
                return Array.from(targetsSelect.options)
                    .filter(function(option) {
                        return option.selected;
                    })
                    .map(function(option) {
                        return {
                            id: option.value,
                            label: option.textContent
                        };
                    });
            }

            function renderSelectedTargetsTable() {
                const container = getTargetsTableContainer();
                const targetsSelect = getTargetsSelect();
                if (!container || !targetsSelect) {
                    console.log('[alertsmanager] renderSelectedTargetsTable: elements not found');
                    return;
                }

                const selectedTargets = getSelectedTargets();
                console.log('[alertsmanager] renderSelectedTargetsTable: selected targets count:', selectedTargets.length);
                
                if (selectedTargets.length === 0) {
                    container.innerHTML = '<div class="alert alert-info small mb-0 mt-2"><i class="ti ti-info-circle"></i> ' + {{ __('No target selected yet', 'alertsmanager')|json_encode()|raw }} + '</div>';
                    console.log('[alertsmanager] renderSelectedTargetsTable: no targets, showing empty message');
                    return;
                }

                let html = '';
                html += '<div class="table-responsive mt-2">';
                html += '<table class="table table-sm table-hover align-middle mb-0 alertsmanager-targets-table">';
                html += '<thead><tr><th>' + {{ __('Selected target', 'alertsmanager')|json_encode()|raw }} + '</th><th class="text-end" style="width: 50px;">' + {{ __('Action', 'alertsmanager')|json_encode()|raw }} + '</th></tr></thead>';
                html += '<tbody>';
                selectedTargets.forEach(function(target) {
                    html += '<tr data-target-id="' + escapeHtml(target.id) + '" class="alertsmanager-target-row">';
                    html += '<td>' + escapeHtml(target.label) + '</td>';
                    html += '<td class="text-end">';
                    html += '<button type="button" class="btn btn-sm btn-outline-danger alertsmanager-remove-target" data-target-id="' + escapeHtml(target.id) + '" title="' + {{ __('Remove target', 'alertsmanager')|json_encode()|raw }} + '">×</button>';
                    html += '</td>';
                    html += '</tr>';
                });
                html += '</tbody></table></div>';
                container.innerHTML = html;
                console.log('[alertsmanager] renderSelectedTargetsTable: rendered table with', selectedTargets.length, 'targets');

                // Attach click handlers to remove buttons
                container.querySelectorAll('.alertsmanager-remove-target').forEach(function(button) {
                    button.addEventListener('click', function(e) {
                        e.preventDefault();
                        const targetId = this.getAttribute('data-target-id');
                        console.log('[alertsmanager] Remove button clicked for target:', targetId);
                        const targetsSelect = getTargetsSelect();
                        if (!targetsSelect) return;

                        const option = targetsSelect.querySelector('option[value="' + CSS.escape(String(targetId)) + '"]');
                        if (!option) {
                            console.warn('[alertsmanager] Option not found for target:', targetId);
                            return;
                        }

                        option.selected = false;
                        console.log('[alertsmanager] Deselected target:', targetId);

                        // Trigger change through jQuery select2 if available
                        if (window.jQuery && window.jQuery(targetsSelect).hasClass('select2-hidden-accessible')) {
                            window.jQuery(targetsSelect).val(
                                Array.from(targetsSelect.options)
                                    .filter(o => o.selected)
                                    .map(o => o.value)
                            ).trigger('change');
                        } else {
                            targetsSelect.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                    });
                });
            }

            function syncSelectUi() {
                const targetsSelect = getTargetsSelect();
                if (!targetsSelect) {
                    return;
                }

                if (window.jQuery) {
                    window.jQuery(targetsSelect).trigger('change.select2');
                    window.jQuery(targetsSelect).trigger('change');
                } else {
                    targetsSelect.dispatchEvent(new Event('change', { bubbles: true }));
                }
                renderSelectedTargetsTable();
            }

            function loadTargets(type) {
                const targetsSelect = getTargetsSelect();
                const targetTypeSelect = getTargetTypeSelect();
                if (!targetsSelect || !targetTypeSelect) {
                    console.log('[alertsmanager] loadTargets: select elements not found');
                    return;
                }

                if (!type) {
                    console.log('[alertsmanager] loadTargets: no type selected, clearing options');
                    // Destroy select2 first if it exists
                    const $select = window.jQuery ? window.jQuery(targetsSelect) : null;
                    if ($select && $select.hasClass('select2-hidden-accessible')) {
                        $select.select2('destroy');
                    }
                    // Clear all options
                    while (targetsSelect.firstChild) {
                        targetsSelect.removeChild(targetsSelect.firstChild);
                    }
                    renderSelectedTargetsTable();
                    return;
                }

                console.log('[alertsmanager] loadTargets: loading targets for type:', type);

                const previouslySelectedIds = Array.from(targetsSelect.options)
                    .filter(function(option) {
                        return option.selected;
                    })
                    .map(function(option) {
                        return option.value;
                    });

                console.log('[alertsmanager] loadTargets: previously selected IDs:', previouslySelectedIds);

                // Destroy select2 if it exists before clearing
                const $select = window.jQuery ? window.jQuery(targetsSelect) : null;
                if ($select && $select.hasClass('select2-hidden-accessible')) {
                    console.log('[alertsmanager] loadTargets: destroying existing select2');
                    $select.select2('destroy');
                }

                // Clear all options using DOM manipulation instead of innerHTML
                while (targetsSelect.firstChild) {
                    targetsSelect.removeChild(targetsSelect.firstChild);
                }

                // Add loading option
                const loadingOption = document.createElement('option');
                loadingOption.textContent = '-- ' + {{ __('Loading', 'alertsmanager')|json_encode()|raw }} + ' --';
                targetsSelect.appendChild(loadingOption);

                renderSelectedTargetsTable();

                const ajaxUrl = '/plugins/alertsmanager/ajax/targets.php?target_type=' + encodeURIComponent(type) + '&limit=5000';
                console.log('[alertsmanager] loadTargets: fetching from:', ajaxUrl);

                fetch(ajaxUrl, {
                    credentials: 'same-origin'
                })
                    .then(function(resp) {
                        console.log('[alertsmanager] loadTargets: fetch response status:', resp.status);
                        if (!resp.ok) {
                            throw new Error('HTTP ' + resp.status);
                        }
                        return resp.json();
                    })
                    .then(function(data) {
                        console.log('[alertsmanager] loadTargets: received', data.length, 'targets');
                        
                        // Clear all options
                        while (targetsSelect.firstChild) {
                            targetsSelect.removeChild(targetsSelect.firstChild);
                        }

                        // Add all fetched options
                        data.forEach(function(item) {
                            const optionEl = document.createElement('option');
                            optionEl.value = String(item.id);
                            optionEl.textContent = item.label;
                            if (previouslySelectedIds.includes(String(item.id))) {
                                optionEl.selected = true;
                                console.log('[alertsmanager] loadTargets: marking', item.label, 'as selected');
                            }
                            targetsSelect.appendChild(optionEl);
                        });

                        // Re-initialize select2 after populating options
                        enhanceTargetsSelect();
                        syncSelectUi();
                    })
                    .catch(function(error) {
                        console.error('[alertsmanager] loadTargets: fetch error:', error);
                        
                        // Clear and show error
                        while (targetsSelect.firstChild) {
                            targetsSelect.removeChild(targetsSelect.firstChild);
                        }
                        const errorOption = document.createElement('option');
                        errorOption.textContent = '-- ' + {{ __('Error loading targets', 'alertsmanager')|json_encode()|raw }} + ' --';
                        targetsSelect.appendChild(errorOption);
                        renderSelectedTargetsTable();
                    });
            }

            function initTargetsLoading() {
                const targetsSelect = getTargetsSelect();
                const targetTypeSelect = getTargetTypeSelect();
                if (!targetsSelect || !targetTypeSelect) {
                    console.log('[alertsmanager] initTargetsLoading: select elements not found, cannot initialize');
                    return;
                }

                console.log('[alertsmanager] initTargetsLoading: initializing targets UI');

                targetsSelect.classList.add('alertsmanager-targets-native');

                targetTypeSelect.addEventListener('change', function() {
                    console.log('[alertsmanager] Target type changed to:', this.value);
                    loadTargets(this.value);
                });

                targetsSelect.addEventListener('change', function() {
                    console.log('[alertsmanager] Targets selection changed');
                    renderSelectedTargetsTable();
                });

                const initialType = '{{ item.fields.target_type|default('') }}';
                console.log('[alertsmanager] Initial target type:', initialType || 'none');
                
                if (initialType) {
                    targetTypeSelect.value = initialType;
                    console.log('[alertsmanager] Loading initial targets for type:', initialType);
                    loadTargets(initialType);
                } else {
                    console.log('[alertsmanager] No initial target type, initializing select2 with empty options');
                    enhanceTargetsSelect();
                    renderSelectedTargetsTable();
                }

                document.addEventListener('click', function(event) {
                    const button = event.target.closest('.alertsmanager-remove-target');
                    if (!button) {
                        return;
                    }

                    const targetId = button.getAttribute('data-target-id');
                    const option = targetsSelect.querySelector('option[value="' + CSS.escape(targetId) + '"]');
                    if (option) {
                        option.selected = false;
                        syncSelectUi();
                    }
                });
            }

            if (document.readyState === 'loading') {
                console.log('[alertsmanager] Page still loading, waiting for DOMContentLoaded');
                document.addEventListener('DOMContentLoaded', initTargetsLoading);
            } else {
                console.log('[alertsmanager] Page already loaded, initializing immediately');
                initTargetsLoading();
            }
        })();
    </script>

{% endblock %}
